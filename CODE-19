FUNCTION OVERLOADING
#include <iostream>
using namespace std;

class Demo
{
public:
    void add(int a, int b)
    {
        cout << "Sum of two numbers = " << a + b << endl;
    }

    void add(int a, int b, int c)
    {
        cout << "Sum of three numbers = " << a + b + c << endl;
    }
};

int main()
{
    Demo obj;

    obj.add(10, 20);
    obj.add(10, 20, 30);

    return 0;
}
OUTPUT
Sum of two numbers = 30
Sum of three numbers = 60
