VIRTUAL FUNCTION
#include <iostream>
using namespace std;

// Base class
class Animal
{
public:
    virtual void sound()
    {
        cout << "Animal makes a sound." << endl;
    }
};

// Derived class
class Dog : public Animal
{
public:
    void sound()
    {
        cout << "Dog barks." << endl;
    }
};

int main()
{
    Animal *ptr;
    Dog d;

    ptr = &d;      // Base class pointer points to derived class object
    ptr->sound();  // Calls derived class function

    return 0;
}
OUTPUT
Dog barks.
