EVEN OR ODD
#include <iostream>
using namespace std;

int main()
{
    int num;

    cout << "Enter a number: ";
    cin >> num;

    if (num % 2 == 0)
        cout << num << " is Even." << endl;
    else
        cout << num << " is Odd." << endl;

    return 0;
}
OUTPUT
Enter a number: 8
8 is Even.Enter a number: 7
7 is Odd.
