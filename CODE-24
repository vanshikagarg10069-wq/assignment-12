CUSTOM EXCEPTION
#include <iostream>
using namespace std;

// Custom Exception Class
class MyException
{
public:
    void message()
    {
        cout << "Custom Exception: Age must be 18 or above." << endl;
    }
};

int main()
{
    int age;

    cout << "Enter your age: ";
    cin >> age;

    try
    {
        if (age < 18)
            throw MyException();

        cout << "You are eligible to vote." << endl;
    }
    catch (MyException e)
    {
        e.message();
    }

    return 0;
}
OUTPUT
Enter your age: 20
You are eligible to vote.
