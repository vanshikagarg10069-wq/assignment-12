PALINDROME
#include <iostream>
using namespace std;

int main()
{
    int num, original, reverse = 0, rem;

    cout << "Enter a number: ";
    cin >> num;

    original = num;

    while (num != 0)
    {
        rem = num % 10;
        reverse = reverse * 10 + rem;
        num = num / 10;
    }

    if (original == reverse)
        cout << original << " is a Palindrome Number." << endl;
    else
        cout << original << " is Not a Palindrome Number." << endl;

    return 0;
}
OUTPUT
Enter a number: 121
121 is a Palindrome Number.
