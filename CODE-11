#include <iostream>
using namespace std;

class Student
{
private:
    int marks;   // Hidden data

public:
    void setMarks(int m)
    {
        marks = m;
    }

    void getMarks()
    {
        cout << "Marks = " << marks << endl;
    }
};

int main()
{
    Student s;

    s.setMarks(85);
    s.getMarks();

    return 0;
}
OUTPUT
Marks = 85
